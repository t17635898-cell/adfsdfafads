local function IsTeam(p)
    local c = p.Character
    if not c then return false end
    local hrp = c:FindFirstChild("HumanoidRootPart")
    return hrp ~= nil and hrp:FindFirstChild("TeammateLabel") ~= nil
end

-- [Target Finder]
local CurrentTarget = nil
task.spawn(function()
    while task.wait(0.1) do
        if library_unloaded then break end
        local best, bestDist = nil, math.huge
        local mousePos = UserInputService:GetMouseLocation()
        for _, p in ipairs(Players:GetPlayers()) do
            if p == LP or IsTeam(p) then continue end
            local c = p.Character; local hrp = c and c:FindFirstChild("HumanoidRootPart"); local hum = c and c:FindFirstChild("Humanoid")
            if not hrp or not hum or hum.Health <= 0 then continue end
            
            local isDangerous = false
            local viewModels = Workspace:FindFirstChild("ViewModels")
            if viewModels then
                for _, m in ipairs(viewModels:GetChildren()) do
                    if m:IsA("Model") then
                        local sp = m.Name:find(" - ", 1, true)
                        if sp and m.Name:sub(1, sp - 1) == p.Name then
                            local w = m.Name:sub(sp + 3):lower()
                            if w:find("katana") or w:find("riot") or w:find("shield") then isDangerous = true end
                            break
                        end
                    end
                end
            end
            if Toggles.AntiWeapon.Value and isDangerous then continue end
            
            local sp, onScreen = Cam:WorldToViewportPoint(hrp.Position)
            if onScreen then
                local dist = (Vector2.new(sp.X, sp.Y) - mousePos).Magnitude
                if dist < bestDist then bestDist = dist; best = p end
            end
        end
        CurrentTarget = best
    end
end)

-- [Silent Aim Logic - From Provided Code]
task.spawn(function()
    local sa_distance = 1000
    local sa_visibility = false
    local sa_target = nil

    local function sa_bite(attr) return string.byte(attr or "\0") end
    local function sa_visible(targetPart, cam)
        if not sa_visibility then return true end
        local dir = (targetPart.Position - cam)
        local params = RaycastParams.new()
        params.FilterType = Enum.RaycastFilterType.Exclude
        params.FilterDescendantsInstances = { LP.Character, targetPart.Parent, Workspace:FindFirstChild("Debris") }
        local result = Workspace:Raycast(cam, dir.Unit * sa_distance, params)
        return result == nil or result.Instance:IsDescendantOf(targetPart.Parent)
    end

    local function sa_valid(plr, cam)
        local char = plr.Character; if not char then return false end
        local hum = char:FindFirstChildOfClass("Humanoid"); local head = char:FindFirstChild("Head")
        if not (hum and head and hum.Health > 0) then return false end
        if (head.Position - cam).Magnitude > sa_distance then return false end
        local ours, theirs = LP:GetAttribute("EnvironmentID"), plr:GetAttribute("EnvironmentID")
        if ours and theirs and sa_bite(ours) ~= sa_bite(theirs) then return false end
        local oursT, theirsT = LP:GetAttribute("TeamID"), plr:GetAttribute("TeamID")
        if oursT and theirsT and sa_bite(oursT) == sa_bite(theirsT) then return false end
        return sa_visible(head, cam)
    end

    local sa_idx
    sa_idx = hookmetamethod(game, "__index", newcclosure(function(self, idx, ...)
        if Toggles.SilentAim.Value and sa_target and not checkcaller() and idx == "ViewportSize" and self == Cam then
            local pos, on = Cam.WorldToViewportPoint(Cam, sa_target)
            if on then return Vector2.new(pos.X * 2, pos.Y * 2) end
        end
        return sa_idx(self, idx, ...)
    end))

    while task.wait(0.1) do
        if library_unloaded then break end
        if Toggles.SilentAim.Value then
            local cam = Cam.CFrame.Position; local best, bestDist = nil, math.huge; local center = Cam.ViewportSize / 2
            for _, plr in Players:GetPlayers() do
                if plr ~= LP and sa_valid(plr, cam) then
                    local pos, on = Cam:WorldToViewportPoint(plr.Character.Head.Position)
                    if on then local d = (Vector2.new(pos.X, pos.Y) - center).Magnitude; if d < bestDist then bestDist, best = d, plr end end
                end
            end
            sa_target = best and best.Character.Head.Position or nil
        else
            sa_target = nil
        end
    end
end)

