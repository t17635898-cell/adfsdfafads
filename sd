-- [Bullet Tracer Logic - Silent Aim 연동 완료]
task.spawn(function()
    local function createBeam(startPos, endPos, color)
        local direction = endPos - startPos; local distance = direction.Magnitude
        if distance <= 0 then return end
        local part = Instance.new("Part")
        part.Anchored = true; part.CanCollide = false; part.CanQuery = false; part.CanTouch = false
        part.Transparency = 0; part.Material = Enum.Material.Neon; part.Color = color or Color3.fromRGB(255, 255, 100)
        part.Size = Vector3.new(0.08, 0.08, distance)
        part.CFrame = CFrame.new(startPos, endPos) * CFrame.new(0, 0, -distance * 0.5)
        part.Parent = workspace
        delay(0.02, function()
            local life = 2; local start = tick()
            local conn; conn = RunService.RenderStepped:Connect(function()
                local t = (tick() - start) / life
                if t >= 1 then conn:Disconnect(); part:Destroy(); return end
                part.Transparency = t
            end)
        end)
    end

    local function setupEquippedItemHook(clientFighter)
        if not clientFighter then return end
        local currentShotConn
        local function setItem(item)
            if currentShotConn then currentShotConn:Disconnect(); currentShotConn = nil end
            if item and item.Shot then
                currentShotConn = item.Shot:Connect(function()
                    if not Toggles.BulletTracer.Value then return end
                    local origin = Cam.CFrame.Position
                    local endPos = origin + Cam.CFrame.LookVector * 2000
                    
                    -- Silent Aim / Auto Fire 켜져있으면 타겟 머리로 광선 그리기
                    if CurrentTarget and CurrentTarget.Character and CurrentTarget.Character:FindFirstChild("Head") and (Toggles.SilentAim.Value or Toggles.AutoFire.Value) then
                        endPos = CurrentTarget.Character.Head.Position
                    else
                        local raycastParams = RaycastParams.new()
                        raycastParams.FilterDescendantsInstances = {LP.Character}
                        raycastParams.FilterType = Enum.RaycastFilterType.Exclude
                        local result = Workspace:Raycast(origin, (endPos - origin), raycastParams)
                        if result then endPos = result.Position end
                    end
                    createBeam(origin, endPos, Color3.fromRGB(255, 255, 100))
                end)
            end
        end
        setItem(clientFighter.EquippedItem)
        clientFighter.EquippedItemChanged:Connect(function(newItem) setItem(newItem) end)
    end

    pcall(function()
        local fighterController = require(LP.PlayerScripts.Controllers.FighterController)
        local localFighter = fighterController:WaitForLocalFighter()
        setupEquippedItemHook(localFighter)
    end)
end)

